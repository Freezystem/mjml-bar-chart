{
    "name": "mjml-bar-chart",
    "version": "3.0.0",
    "author": "freezystem <freezystem@gmail.com>",
    "homepage": "https://github.com/Freezystem/mjml-bar-chart",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Freezystem/mjml-bar-chart.git"
    },
    "bugs": "https://github.com/Freezystem/mjml-bar-chart/issues",
    "description": "A simple MJML component to make static bar charts",
    "keywords": [
        "mjml",
        "chart",
        "charts",
        "bar",
        "bars",
        "email"
    ],
    "license": "MIT",
    "type": "module",
    "exports": {
        "types": "./build/types/index.d.ts",
        "import": "./build/esm/index.js",
        "require": "./build/cjs/index.js"
    },
    "files": [
        "build/**/*",
        "src/**/*"
    ],
    "engines": {
        "node": ">=20",
        "npm": ">=11"
    },
    "scripts": {
        "watch": "tsc --watch",
        "prebuild": "rm -rf build",
        "build": "tsc -b tsconfig.json tsconfig.esm.json tsconfig.types.json",
        "postbuild": "mkdir -p build/cjs && echo '{\"type\":\"commonjs\"}' > build/cjs/package.json",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "test:snap": "vitest -u",
        "deps": "ncu -i --format group --install always --peer",
        "postdeps": "npm audit fix",
        "format": "biome format",
        "format:fix": "biome format --write",
        "lint": "biome lint",
        "lint:fix": "biome lint --write",
        "fl": "biome check",
        "fl:fix": "biome check --write",
        "fl:ci": "biome ci --reporter=github",
        "preversion": "git reset && git switch main && git fetch -p && git pull",
        "postversion": "npm run tag:push",
        "tag:push": "git push && git push --tags",
        "tag:delete": "git tag -d ${npm_config_tag} && git push origin :refs/tags/${npm_config_tag}"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.3",
        "@types/mjml": "^5.0.0",
        "@types/mjml-core": "^5.0.0",
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "mjml": "^5.4.0",
        "mjml-core": "^5.4.0",
        "npm-check-updates": "^22.2.9",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "mjml": "^5.0.0",
        "mjml-core": "^5.0.0"
    }
}
